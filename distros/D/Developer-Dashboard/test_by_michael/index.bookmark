TITLE: Developer Dashboard
:--------------------------------------------------------------------------------:
BOOKMARK: /app/index
:--------------------------------------------------------------------------------:
STASH: 
  splat => [
    'index',
  ],
  user => 'mv',
:--------------------------------------------------------------------------------:
HTML: <style>
    :root{
      --bg: #0b1220;
      --panel: rgba(255,255,255,0.06);
      --panel-2: rgba(255,255,255,0.08);
      --text: rgba(255,255,255,0.92);
      --muted: rgba(255,255,255,0.70);
      --border: rgba(255,255,255,0.12);
      --shadow: 0 14px 40px rgba(0,0,0,0.35);
      --radius: 16px;
      --accent: #7dd3fc;
      --accent-2: #a78bfa;
    }

    *{ box-sizing: border-box; }
    html, body { height: 100%; }
    body{
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
      color: var(--text);
      background:
        radial-gradient(1100px 600px at 20% -10%, rgba(125,211,252,0.22), transparent 60%),
        radial-gradient(900px 500px at 90% 10%, rgba(167,139,250,0.20), transparent 55%),
        radial-gradient(800px 500px at 50% 110%, rgba(34,211,238,0.10), transparent 60%),
        var(--bg);
    }

    .wrap{
      max-width: 1100px;
      margin: 0 auto;
      padding: 28px 18px 42px;
    }

    header{
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    .title{
      display: grid;
      gap: 6px;
    }

    .title h1{
      font-size: 26px;
      margin: 0;
      letter-spacing: 0.2px;
    }
    .title p{
      margin: 0;
      color: var(--muted);
      font-size: 14px;
    }

    .grid{
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 16px;
      margin-top: 16px;
    }

    .card{
      grid-column: span 12;
      background: linear-gradient(180deg, var(--panel), rgba(255,255,255,0.03));
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .card h2{
      margin: 0;
      padding: 16px 18px 12px;
      font-size: 16px;
      letter-spacing: 0.3px;
      color: rgba(255,255,255,0.9);
      display: flex;
      align-items: center;
      gap: 10px;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.02);
    }

    .card .content{
      padding: 14px 12px 16px;
    }

    .list{
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .item a{
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 12px;
      border-radius: 12px;
      text-decoration: none;
      color: var(--text);
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      transition: transform 120ms ease, background 120ms ease, border-color 120ms ease;
    }

    .item a:hover{
      transform: translateY(-1px);
      background: rgba(255,255,255,0.06);
      border-color: rgba(125,211,252,0.22);
    }

    .left{
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
    }

    .icon{
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 10px;
      background: linear-gradient(135deg, rgba(125,211,252,0.25), rgba(167,139,250,0.18));
      border: 1px solid rgba(255,255,255,0.10);
      flex: 0 0 auto;
    }

    .label{
      display: grid;
      gap: 2px;
      min-width: 0;
    }

    .label .name{
      font-weight: 600;
      font-size: 14px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .label .hint{
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .chip{
      font-size: 12px;
      padding: 6px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.03);
      color: rgba(255,255,255,0.78);
      flex: 0 0 auto;
    }

    hr{
      border: none;
      border-top: 1px solid rgba(255,255,255,0.12);
      margin: 18px 0;
    }

    @media (min-width: 720px){
      .card.span-6{ grid-column: span 6; }
      .card.span-4{ grid-column: span 4; }
    }
  </style>

<body>
  <div class="wrap">
