SV*
freeze(SV* self_sv)
    CODE:
        EXTRACT_MAP(HashMapSS, stash_ss, "Data::HashMap::SS", self_sv);
        uint32_t now = self->expires_at ? (uint32_t)time(NULL) : 0;
        SV* buf = newSV(22 + self->size * 32);
        SvPOK_on(buf);
        SvCUR_set(buf, 0);
        /* Header: magic(4) + version(1) + variant_id(1) + count(4) + max_size(4) + ttl(4) + lru_skip(4) */
        sv_catpvn(buf, "DHMP", 4);
        { uint8_t ver = 1; sv_catpvn(buf, (const char*)&ver, 1); }
        { uint8_t vid = 4; sv_catpvn(buf, (const char*)&vid, 1); }
        STRLEN cnt_offset = SvCUR(buf);
        { uint32_t cnt = 0; sv_catpvn(buf, (const char*)&cnt, 4); }
        UV n_written = 0;
        { uint32_t ms = (uint32_t)self->max_size; sv_catpvn(buf, (const char*)&ms, 4); }
        { uint32_t dt = self->default_ttl; sv_catpvn(buf, (const char*)&dt, 4); }
        { uint32_t ls = self->lru_skip; sv_catpvn(buf, (const char*)&ls, 4); }
        { size_t i;
          for (i = 0; i < self->capacity; i++) {
            if (SS_NODE_LIVE(self->nodes[i]) && !HM_TTL_SKIP_EXPIRED(self, i, now)) {
                uint32_t kl = HM_UNPACK_LEN(self->nodes[i].key_len);
                uint8_t ku = HM_UNPACK_UTF8(self->nodes[i].key_len) ? 1 : 0;
                sv_catpvn(buf, (const char*)&kl, 4);
                sv_catpvn(buf, (const char*)&ku, 1);
                sv_catpvn(buf, self->nodes[i].key, kl);
                uint32_t vl = HM_UNPACK_LEN(self->nodes[i].val_len);
                uint8_t vu = HM_UNPACK_UTF8(self->nodes[i].val_len) ? 1 : 0;
                sv_catpvn(buf, (const char*)&vl, 4);
                sv_catpvn(buf, (const char*)&vu, 1);
                if (self->nodes[i].value) sv_catpvn(buf, self->nodes[i].value, vl);
                /* TTL: remaining seconds (0 = none) */
                { uint32_t rem = 0;
                  if (self->expires_at && self->expires_at[i] && self->expires_at[i] > now)
                      rem = self->expires_at[i] - now;
                  sv_catpvn(buf, (const char*)&rem, 4);
                }
                n_written++;
            }
          }
        }
        { uint32_t actual = (uint32_t)n_written;
          memcpy(SvPVX(buf) + cnt_offset, &actual, 4); }
        RETVAL = buf;
    OUTPUT:
        RETVAL

SV*
thaw(char* class, SV* data)
    CODE:
        STRLEN dlen;
        const uint8_t* p = (const uint8_t*)SvPV(data, dlen);
        const uint8_t* end = p + dlen;
        if (dlen < 22 || memcmp(p, "DHMP", 4) != 0) croak("Invalid freeze data");
        p += 4;
        uint8_t ver = *p++; if (ver != 1) croak("Unsupported freeze version %d", ver);
        uint8_t vid = *p++; if (vid != 4) croak("Variant mismatch: expected 4, got %d", vid);
        uint32_t cnt; memcpy(&cnt, p, 4); p += 4;
        uint32_t ms; memcpy(&ms, p, 4); p += 4;
        uint32_t dt; memcpy(&dt, p, 4); p += 4;
        uint32_t ls; memcpy(&ls, p, 4); p += 4;
        HashMapSS* map = hashmap_ss_create((size_t)ms, dt, ls);
        if (!map) croak("Failed to create map for thaw");
        if (cnt > 0) hashmap_ss_reserve(map, (size_t)cnt);
        { uint32_t j;
          for (j = 0; j < cnt; j++) {
            if (p + 14 > end) { hashmap_ss_destroy(map); croak("Truncated freeze data"); }
            uint32_t kl; memcpy(&kl, p, 4); p += 4;
            uint8_t ku = *p++; bool kutf8 = ku ? true : false;
            if (p + kl + 5 > end) { hashmap_ss_destroy(map); croak("Truncated freeze data"); }
            const char* kstr = (const char*)p; p += kl;
            uint32_t khash = hm_hash_string(kstr, kl);
            uint32_t vl; memcpy(&vl, p, 4); p += 4;
            uint8_t vu = *p++; bool vutf8 = vu ? true : false;
            if (p + vl + 4 > end) { hashmap_ss_destroy(map); croak("Truncated freeze data"); }
            const char* vstr = (const char*)p; p += vl;
            uint32_t ttl; memcpy(&ttl, p, 4); p += 4;
            hashmap_ss_put(map, kstr, kl, khash, kutf8, vstr, vl, vutf8, ttl);
          }
        }
        if (p > end) croak("Truncated freeze data");
        RETVAL = sv_setref_pv(newSV(0), class, (void*)map);
    OUTPUT:
        RETVAL


