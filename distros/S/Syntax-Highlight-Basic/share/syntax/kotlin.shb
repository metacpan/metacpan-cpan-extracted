[keyword:Repeat]
do for while

[keyword:Statement]
break continue return

[keyword:StorageClass]
abstract actual annotation companion crossinline dynamic enum expect external
final inline inner noinline open override reified sealed suspend vararg

[keyword:Structure]
class constructor fun init interface object typealias val var

