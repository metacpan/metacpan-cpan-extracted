# Avoid version control files
\bRCS\b
\bCVS\b
,v$
\.svn/
\.git/
\.gitignore$

# Avoid temp and backup files
~$
\.old$
\#$
\.#
\.bak$
\.tmp$

# Avoid editor/tool config
^\.claude/
^CLAUDE\.md$

# Avoid OS-specific files
\.DS_Store$
\bdesktop\.ini$

# Avoid build files
^Makefile$
^Makefile\.old$
^blib/
^pm_to_blib$
^blibdirs$
^MYMETA\b
^Nats\.c$
^Nats\.xs$
^Nats\.o$
\.o$
\.bs$
^src/ppport\.h$

# Avoid archive
\.tar\.gz$

# MANIFEST.bak
^MANIFEST\.bak$
