        ["\x87\x8F",'keis83','cp932',{'INPUT_LAYOUT'=>'D'},"\x72\xF7"], # ćÅ 878F 72F7
        ["\x87\x7E",'keis83','cp932',{'INPUT_LAYOUT'=>'D'},"\x73\xF8"], # ć~ 877E 73F8
        ["\x87\x93",'keis83','cp932',{'INPUT_LAYOUT'=>'D'},"\x6F\xB8"], # ćō 8793 6FB8
