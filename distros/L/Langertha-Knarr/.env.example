# Knarr — API Keys
# Copy this to .env and fill in your keys:
#   cp .env.example .env
#
# Knarr auto-detects which providers are available.
# Only set the ones you want to use.

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
#GROQ_API_KEY=
#MISTRAL_API_KEY=
#DEEPSEEK_API_KEY=
#MINIMAX_API_KEY=
#GEMINI_API_KEY=
#OPENROUTER_API_KEY=
#PERPLEXITY_API_KEY=
#CEREBRAS_API_KEY=

# Langfuse Tracing (optional — enables automatic observability)
#LANGFUSE_PUBLIC_KEY=pk-lf-...
#LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_URL is set to http://langfuse:3000 in docker-compose.yml

# Proxy Authentication (optional — protects your proxy)
#KNARR_API_KEY=
