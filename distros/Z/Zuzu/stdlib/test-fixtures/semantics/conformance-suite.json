			"file": "conf-runtime-dict-keys.zzs",
			"source": "function __fixture_result () {\n\tlet keys := { zebra: 1, ant: 2, lemon: 3 }.sorted_keys();\n\treturn keys[0] _ \",\" _ keys[1] _ \",\" _ keys[2];\n}\n",
			"expected": "ant,lemon,zebra"
