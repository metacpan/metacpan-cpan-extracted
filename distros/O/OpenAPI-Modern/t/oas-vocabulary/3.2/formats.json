            "type": "integer"
        },
        "tests": [
            {
                "description": "beyond int64 lower boundary",
                "data": -9223372036854775809,
                "valid": true
            },
            {
                "description": "int64 lower boundary",
                "data": -9223372036854775808,
                "valid": true
            },
            {
                "description": "beyond int32 lower boundary",
                "data": -2147483649,
                "valid": true
            },
