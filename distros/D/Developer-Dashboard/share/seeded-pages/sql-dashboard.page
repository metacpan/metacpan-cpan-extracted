# sql_dashboard_list_drivers()
# Purpose: discover installed DBD::* modules visible to the sql-dashboard bookmark worker.
# Input: none.
# Output: array reference of sorted DBD::* module names.
sub sql_dashboard_list_drivers {
    my %drivers;
    for my $inc (@INC) {
