#!/usr/bin/env perl

use v5.38;
use experimental qw(signatures);
use Syntax::Operator::In;

use Digest;
use Fcntl qw(:flock O_RDONLY O_RDWR);
use File::Path qw(make_path);
use File::Spec;
use File::Temp;
use Getopt::Long qw(GetOptionsFromArray);
use JSON::PP;
use Time::Piece;
use YAML::PP;

use constant {
    ISO_DATE_FMT => '%Y-%m-%dT%H:%M:%S',
};

my $DEBUG = 0;
my $VERBOSE = 0;
my $json = JSON::PP->new->utf8->canonical;
my $digest = Digest->new('SHA-256');

my @config_locations = (
    $ENV{SSHCA_CONF} ? ($ENV{SSHCA_CONF},) : (),
    '/etc/sshca/sshca.conf',
    '/usr/local/etc/sshca/sshca.conf',
    '/opt/sshca/etc/sshca.conf',
    );

my %conf_envvars = (
    basedir => 'SSHCA_HOME'
    );

my %conf_handlers = (
    basedir           => sub($value) {
        $value
        // ($ENV{HOME} ? File::Spec->catdir( $ENV{HOME}, 'sshca' )
            : File::Spec->catdir( '.', 'sshca' ))
    },
    ca_keytype        => sub($value) { $value // 'ed25519' },
    cadir             => sub($value) { $value // File::Spec->catdir( opt( 'basedir' ), 'ca' ) },
    caserial          => sub($) { File::Spec->catfile( opt( 'cadir' ), 'serial' ) },
    certsdir          => sub($value) { $value // File::Spec->catdir( opt( 'basedir' ), 'certs' ) },
    certtype          => sub($value) { $value // 'user' },
    configdir         => sub($) {
        my $conf = opt( 'config' );
        return unless $conf;
        my ($vol, $dirs,) = File::Spec->splitpath( $conf );
        File::Spec->catpath( $vol, $dirs );
    },
    fpdir             => sub($value) { $value // File::Spec->catdir( opt( 'basedir' ), 'fingers' ) },
    hostca_key        => sub($value) { $value // File::Spec->catfile( opt( 'cadir' ), 'hostca' ) },
    hostca_pubkey     => sub($value) { opt( 'hostca_key' ) . '.pub' },
    hostcert_validity => sub($value) { $value // '+53w' },
    identdir          => sub($value) { $value // File::Spec->catdir( opt( 'basedir' ), 'idents' ) },
    userca_key        => sub($value) { $value // File::Spec->catfile( opt( 'cadir' ), 'userca' ) },
    userca_pubkey     => sub($value) { opt( 'userca_key' ) . '.pub' },
    usercert_validity => sub($value) { $value // '+13w1d' },
    );

my %options = ();
my %config = ();

sub opt($opt, $value = undef) {
    my $default = defined $value ? $value : '<undef>';
    say "Resolving option '$opt' with default value '$default'"
        if $DEBUG;
    $options{$opt} = $value if defined $value;
    my $val = $options{$opt} // ($conf_envvars{$opt} ? $ENV{$conf_envvars{$opt}} : undef) // $config{$opt};
    if (my $h = $conf_handlers{$opt}) {
        $val = $h->($val);
    }
    my $str_val = defined $val ? $val : '<undef>';
    say "Option '$opt' resolved to: '$str_val'"
        if $DEBUG;
    return $val;
}

my $yaml = YAML::PP->new;

sub configure() {
    for my $l (@config_locations) {
        if (-r $l) {
            open my $fh, '<:encoding(UTF-8)', $l
                or die "Failed to open '$l': $!";
            my $content = <$fh>;
            my $cfg = $yaml->load_string( "---\n" . $content ) || {};
            %config = $cfg->%*;

            return;
        }
    }
}

sub _map_certs($dir, $cb) {
    opendir( my $dh, $dir )
        or die "Could not open directory '$dir': $!";

    for my $file ( File::Spec->no_upwards( readdir($dh) ) ) {
        my $path = File::Spec->catfile( $dir, $file );

        if (-d $path) {
            _map_certs( $path, $cb );
        } else {
            $cb->( cert_load_from_path( $path ), $path );
        }
    }

    closedir($dh);
}

sub map_certs($cb) {
    _map_certs( opt( 'certsdir' ), $cb );
    return;
}

sub hashed_path($parent, $i, $create = undef) {
    # pass in an identifier
    $digest->reset;
    $digest->add( "$i" );
    my $hash = $digest->hexdigest;
    $hash =~ m/^(..)(..)/;

    my $dir = File::Spec->catdir( $parent, $1, $2 );
    if ($create) {
        make_path $dir;
        ###TODO: verify success!
    }
    return File::Spec->catfile( $dir, $hash );
}

sub identity_path($id_or_cert) {
    my $id = (ref $id_or_cert)
        ? cert_identity($id_or_cert) : $id_or_cert;

    $digest->reset;
    $digest->add( "$id" );

    return File::Spec->catfile( opt( 'identdir' ), $digest->hexdigest );
}


#### CERT METHODS

sub cert_new($identity, %args) {
    return {
        id => $identity,
        type => $args{type} // 'user',
        schema_version => "1",
        state => 'ISSUED',
        %args{qw(pubkey principals options validity)}
    };
}

sub cert_renew($cert, $serial) {
    return {
        $cert->%*, serial => $serial, state => 'ISSUED'
    };
}

sub _cert_path($serial_or_cert, $local, $create) {
    my $serial = (ref $serial_or_cert)
        ? $serial_or_cert->{serial} : $serial_or_cert;

    my $hashed_path = hashed_path(
        $local ? 'certs' : opt( 'certsdir' ),
        $serial,
        $create
    );
    return "$hashed_path.json";
}

sub cert_local_path($serial_or_cert, $create = undef) {
    return _cert_path($serial_or_cert, 1, $create);
}

sub cert_path($serial_or_cert, $create = undef) {
    return _cert_path($serial_or_cert, 0, $create);
}

sub cert_load_from_path($path) {
    open(my $fh, '<:encoding(UTF-8)', $path)
        or die "Unable to open certificate file '$path': $!";
    return $json->decode( do { local $/ = undef; <$fh> } );
}

sub cert_load($serial) {
    my $path = cert_path($serial);
    open(my $fh, '<:encoding(UTF-8)', $path)
        or die "Unable to open certificate file for serial '$serial': $!";

    my $rv;
    unless (eval { $rv = $json->decode( do { local $/ = undef; <$fh> } ); 1; }) {
        die "Failed to load cert data from '$path': $@";
    }

    return $rv;
}

sub cert_load_from_identity($id) {
    my $path = identity_path($id);
    return cert_load_from_path($path);
}

sub _cert_save_identity_link($cert, $replace) {
    my $id_path = identity_path($cert);
    unlink $id_path if $replace and -e $id_path;
    # todo: check success
    symlink( File::Spec->catfile( File::Spec->updir, cert_local_path($cert) ),
             $id_path );
    # todo: check success
}

sub cert_save($cert) {
    my $serial = cert_serial( $cert );
    my $path = cert_path( $serial, 1 );

    unless (-e $path) {
        _cert_save_identity_link($cert, 1);
    }
    open(my $fh, '>:encoding(UTF-8)', $path)
        or die "Unable to create certificate file for serial '$serial'";
    print $fh $json->encode( $cert );
}


#### CERT accessors

sub cert_certkey($cert, $certkey = undef) {
    $cert->{certkey} = $certkey if defined $certkey;
    return $cert->{certkey};
}

sub cert_identity($cert, $id = undef) {
    $cert->{id} = $id if defined $id;
    return $cert->{id};
}

sub cert_options($cert, $options = undef) {
    $cert->{options} = $options if defined $options;
    return $cert->{options} ? $cert->{options}->@* : ();
}

sub cert_principals($cert, $principals = undef) {
    $cert->{principals} = $principals if defined $principals;
    return $cert->{principals} ? $cert->{principals}->@* : ();
}

sub cert_pubkey($cert, $pubkey = undef) {
    $cert->{pubkey} = $pubkey if defined $pubkey;
    return $cert->{pubkey};
}

sub cert_state($cert, $state = undef) {
    $cert->{state} = $state if defined $state;
    return $cert->{state};
}

sub cert_serial($cert, $serial = undef) {
    $cert->{serial} = $serial if defined $serial;
    return $cert->{serial};
}

sub cert_type($cert, $type = undef) {
    $cert->{type} = $type if defined $type;
    return $cert->{type};
}

sub cert_validity($cert, $validity = undef) {
    $cert->{validity} = $validity if defined $validity;
    return $cert->{validity};
}


#############

sub conf_curr_serial() {
    my $serialpath = opt( 'caserial' );
    sysopen(my $fh, $serialpath, O_RDONLY)
        or die "Unable to read current serial value; can't open '$serialpath': $!\n";
    flock( $fh, LOCK_SH )
        or die "Unable to lock the serial file for reading: $!\n";

    chomp( my $serial = <$fh> );
    return $serial;
}

sub conf_next_serial() {
    my $serialpath = opt( 'caserial' );
    sysopen(my $fh, $serialpath, O_RDWR)
        or die "Unable to generate new cert serial number; can't open '$serialpath': $!\n";
    flock( $fh, LOCK_EX )
        or die "Unable to lock the serial file for update: $!\n";
    chomp( my $serial = <$fh> );
    seek( $fh, SEEK_SET, 0 )
        or die "Unable to update certificate serial number: $!\n"; # back to start
    print $fh ($serial + 1);
    return $serial;
}

########### SSH ssh_keygen routines

sub _cert_issue_create_dir($cert) {
    my $dir = File::Temp->newdir( CLEANUP => 1 );
    my $pubkey = File::Temp->new( CLEANUP => 1, DIR => $dir->dirname );
    print $pubkey cert_pubkey($cert);

    return { dir => $dir, pubkey => $pubkey };
}

sub _cert_issue_pubkey_file($dir) {
    return $dir->{pubkey}->filename;
}

sub _cert_issue_cert_file($dir) {
    my $fn = _cert_issue_pubkey_file($dir);
    return "$fn-cert.pub";
}

sub ssh_cert_issue($cert) {
    my @cmd_args = qw(ssh-keygen -q);
    my $dir = _cert_issue_create_dir( $cert );
    my $pubkey_fn = _cert_issue_pubkey_file( $dir );
    push @cmd_args, '-h'
        if cert_type( $cert ) eq 'host';
    push @cmd_args, ('-I', cert_identity( $cert ));

    if (my @principals = cert_principals( $cert )) {
        push @cmd_args, ('-n', join(',', @principals));
    }
    if (my @options = cert_options( $cert )) {
        push @cmd_args, (map { ('-O', $_) } @options);
    }
    if (my $validity = cert_validity( $cert )) {
        push @cmd_args, ('-V', $validity);
    }
    if (my $serial = cert_serial( $cert )) {
        push @cmd_args, ('-z', $serial);
    }

    my $ca;
    if (cert_type( $cert ) eq 'host') {
        $ca = opt( 'hostca_key' );
    }
    else {
        $ca = opt( 'userca_key' );
    }
    push @cmd_args, '-s', $ca, $pubkey_fn;

    say STDERR join(' ', map { "'$_'" } @cmd_args)
        if $DEBUG;

    system @cmd_args;
    my $certfile = _cert_issue_cert_file( $dir );
    my $certkey = `cat $certfile`;
    chomp $certkey;

    cert_certkey( $cert, $certkey );
}

sub ssh_cert_parse($cert) {
    my $fh = File::Temp->new;
    my $fn = $fh->filename;

    my $certkey = cert_certkey( $cert );
    say $fh $certkey;
    $fh->flush;

    my %rv;
    my $indent = '';
    my $multivalue = '';
    my @lines = qx|ssh-keygen -q -L -f $fn|;
    if ($?) {
        my $code = $? >> 8;
        my $id = cert_identity( $cert );
        my $serial = cert_serial( $cert );
        die "Failed to parse certificate '$id' (serial '$serial'); ssh-keygen exit code: $code\ncertificate: $certkey\n";
    }
    for my $line (@lines) {
        if ($multivalue) {
            if ($line =~ m/$indent\s+(.*)$/) {
                push $rv{$multivalue}->@*, $1;
                next;
            }
            else {
                $multivalue = '';
            }
        }
        $line =~ m/(?<INDENT>\s+)(?<NAME>[^:]+):\s(?<VALUE>.*)/
            or next;
        my %r = %+;

        $indent = $r{INDENT};
        if ($r{NAME} eq 'Valid') {
            if ($r{VALUE} =~ m/(?:from (\d{4}-\d\d-\d\dT\d\d:\d\d:\d\d))/) {
                $rv{Valid}->{from} = Time::Piece->strptime( $1, ISO_DATE_FMT );
            }
            if ($r{VALUE} =~ m/(?:to (\d{4}-\d\d-\d\dT\d\d:\d\d:\d\d))/) {
                $rv{Valid}->{to} = Time::Piece->strptime( $1, ISO_DATE_FMT );
            }
        }
        else {
            if ($r{VALUE} eq '(none)') {
                $rv{$r{NAME}} = [];
            }
            elsif ($r{VALUE} eq '') {
                $rv{$r{NAME}} = [];
                $multivalue = $r{NAME};
            }
            else {
                $rv{$r{NAME}} = $r{VALUE};
            }
        }
    }
    \%rv;
}


########## COMMANDS

sub _init_ca_key( %args ) {
    my @args = (
        'ssh-keygen',
        '-q',
        '-N', '',
        '-t', opt( 'ca_keytype' ),
        '-f', File::Spec->catfile( opt( 'cadir' ), $args{name} ),
        );
    if ($args{comment}) {
        push @args, ('-C', $args{comment});
    }

    say STDERR "Generating $args{name} key: " . join(' ', map { qq{"$_"} } @args)
        if $DEBUG;
    system(@args);
}

sub _init_upgrade( $basedir ) {
    say "Upgrading existing certificate authority at '$basedir'";

    my $serial = conf_curr_serial();

    my $identdir = opt( 'identdir' );
    unless (-e $identdir) {
        say "  Creating identities store: $identdir";
        make_path $identdir;
        # todo check success

        for my $upgrade_serial (reverse (1 .. $serial-1)) {
            my $cert = eval { cert_load($upgrade_serial) };
            next if not $cert;

            say "    Upgrading certificate store for serial $upgrade_serial";
            _cert_save_identity_link( $cert, 0 );
        }
    }

    return 0;
}

sub cmd_init(@args) {
    say 'Initialization started with arguments: ' . join(', ', map { "'$_'" } @args)
        if $DEBUG;

    my $basedir = opt( 'basedir', (shift @args) );
    return _init_upgrade( $basedir )
        if $options{upgrade};

    my $serial = $options{serial} //= 1;
    die "Unable to create CA base directory '$basedir': Path exists\n"
        if -e $basedir;
    make_path $basedir;
    make_path opt( 'cadir' );
    make_path opt( 'certsdir' );
    make_path opt( 'identdir' );
    ### TODO! Check successful creation of the directories!

    _init_ca_key( name => 'hostca', comment => opt( 'hostca_keycomment' ) );
    _init_ca_key( name => 'userca', comment => opt( 'userca_keycomment' ) );

    open my $fh, '>:encoding(UTF-8)', opt( 'caserial' )
        or die "Unable to create serial file: $!\n";
    print $fh $serial;

    my $hostca_pubkey = opt( 'hostca_pubkey' );
    my $userca_pubkey = opt( 'userca_pubkey' );
    say "Successfully created SSH CA directory $basedir";

    say <<~EOF if $VERBOSE;

      Please find how to install the user CA public key from '$hostca_pubkey'
      on your servers to recognize certificates of users logging in:
         https://github.com/ehuelsmann/perl-sshca/...

      Please find how to install the host CA public key '$userca_pubkey'
      on your clients to recognize certificates of hosts being logged into:
         https://github.com/ehuelsmann/perl-sshca/...
      EOF

    return 0;
}

sub _validity_for_cert( $cert ) {
    return $options{validity} if defined $options{validity};
    my $cert_validity = cert_validity( $cert );
    return $cert_validity
        if (defined $cert_validity
            and $cert_validity =~ m/^[+-]/); # relative validity
    if (cert_type( $cert ) eq 'host') {
        return opt( 'hostcert_validity' );
    }
    return opt( 'usercert_validity' );
}

sub cmd_issue(@args) {
    my $type = opt( 'certtype' );

    my $identity = shift @args;
    my $pubkey_file = (shift @args) || '-'; # map empty string to '-' too!
    my $pubkey_fh;

    if (not defined $identity) {
        die <<~EOF;
        Missing identity parameter!

        Usage:
          sshca issue [options...] <identity> [pubkey path]
        EOF
    }
    if ($pubkey_file eq '-') {
        say STDERR "Reading public key from standard input for identity '$identity'";
        $pubkey_fh = *STDIN;
    }
    else {
        open($pubkey_fh, '<:encoding(UTF-8)', $pubkey_file)
            or die "Unable to open public key file ($pubkey_file): $!";
    }
    my $pubkey = do { local $/ = undef; <$pubkey_fh> };
    chomp $pubkey;
    my $validity = $options{validity};
    unless (defined $validity) {
        if ($type eq 'host') {
            $validity = opt( 'hostcert_validity' );
        }
        else {
            $validity = opt( 'usercert_validity' );
        }
    }
    my $cert = cert_new( $identity,
                         pubkey => $pubkey,
                         options => opt( 'certoptions' ),
                         principals => opt( 'certprincipals' ),
                         type => $type );
    my $serial = cert_serial( $cert, conf_next_serial() );
    cert_validity( $cert, _validity_for_cert( $cert ) );

    ssh_cert_issue( $cert );
    cert_save( $cert );
    my $Type = ucfirst( $type );
    say STDERR "$Type certificate with identity '$identity' and serial number $serial:";
    say cert_certkey( $cert );

    return 0;
}

sub cmd_renew(@args) {
    my $identifier = shift @args;
    my $cert;

    if ( not defined $options{renewal}
         or $options{renewal} eq 'serial' ) {
        warn "No renewal type defined; assuming 'serial' renewal\n"
            if not exists $options{renewal};
        $cert = cert_load( $identifier );
    }
    elsif ( $options{renewal} eq 'identity' ) {
        $cert = cert_load_from_identity( $identifier );
    }

    my $new_serial  = conf_next_serial;
    my $renewed     = cert_renew( $cert, $new_serial );
    cert_validity( $renewed, _validity_for_cert( $renewed ) );
    cert_identity( $renewed, $options{new_identity} )
        if $options{new_identity};
    ssh_cert_issue( $renewed );
    cert_save( $renewed );

    cert_state( $cert, 'RENEWED' );
    cert_save( $cert );

    say cert_certkey( $renewed );

    return 0;
}

sub cmd_revoke(@args) {
    my $serial = shift @args;
    my $cert = cert_load( $serial );

    cert_state( $cert, 'REVOKED' );
    cert_save( $cert );

    return 0;
}

sub cmd_history(@args) {
    return 0;
}

sub _filter_expiry($cb) {
    say STDERR "Filtering by expiry: $options{expiry}";
    my $before = Time::Piece->strptime( $options{expiry}, ISO_DATE_FMT );
    sub ($cert_data, $cert, @rest) {
        return unless ($cert_data->{Valid}
                       and $cert_data->{Valid}->{to}
                       and $cert_data->{Valid}->{to} < $before);
        $cb->($cert_data, $cert, @rest);
    }
}

sub _filter_states($cb, $states) {
    say STDERR "Filtering certs by states: " . join(', ', $states->@*);
    sub ($cert_data, $cert, @rest) {
        return unless $cert->{status} in:eq $states->@*;
        $cb->($cert_data, $cert, @rest);
    }
}

sub _filter_wrap_parsed_cert($cb) {
    sub ($cert, @rest) {
        my $data = ssh_cert_parse( $cert );
        $cb->( $data, $cert, @rest );
    }
}

sub cmd_list(@args) {
    my $matched = '';
    my $fn =
        sub ($cert_data, $cert, $path, @) {
            my $cert_path = cert_path( $cert->{serial} );
            my $enddate = $cert_data->{Valid}->{to};
            $enddate = $enddate ? ('/' . $enddate->datetime) : '';
            my $cert_id     = cert_identity($cert);
            my $cert_serial = cert_serial($cert);
            my $cert_state  = cert_state($cert);
            say "$cert_serial/$cert_state/$cert_id$enddate";
            $matched = 1;
    };
    $fn = _filter_expiry( $fn )
        if $options{expiry};
    $fn = _filter_states( $fn, $options{states} )
        if $options{states};
    $fn = _filter_wrap_parsed_cert( $fn );
    map_certs($fn);

    # exit code as 'grep':
    return ($matched ? 0 : 1);
}

sub _cleanup_remove_cert( $cert ) {
    my $i = identity_path( $cert );
    if (-s $i) {
        my $loc = cert_local_path( $cert );
        my $tgt = readlink( $i );
        die "Unable to read symlink '$i': $!\n"
            unless $tgt;

        my $cert_link = File::Spec->catfile( File::Spec->updir, $loc );
        say STDERR "$tgt == $cert_link" if $DEBUG;
        if ($tgt eq $cert_link) {
            if (not $options{'dry-run'}
                and unlink( $i ) != 1) {
                die "Unable to remove certificate identity path '$i': $!\n";
            }
        }
    }

    my $path = cert_path( $cert );
    if (-e $path) {
        if (-f $path) {
            if (not $options{'dry-run'}
                and unlink( $path ) != 1) {
                die "Unable to remove certificate path '$path': $!\n";
            }
        }
        else {
            die "Failed to remove certificate '$path': file expected\n";
        }
    }
}

sub cmd_cleanup(@args) {
    my $now = gmtime();
    say "Dry-run cleanup\n" if $options{"dry-run"};
    map_certs(
        sub ($cert, $path, @) {
            my $certkey = cert_certkey( $cert );
            unless ( $certkey ) { # defined and non-zero length
                my $serial = cert_serial( $cert );
                say STDERR "Internal structure error: certificate '$serial' has no data  (path: $path)";
                say "Removing certificate '$serial'";

                _cleanup_remove_cert( $cert );
                return;
            }


            my $data = ssh_cert_parse( $cert );
            my $enddate = $data->{Valid}->{to};
            if ($enddate
                and $enddate < $now) {
                say "Removing expired cert with serial '$cert->{serial}'";
                _cleanup_remove_cert( $cert );
            }
        });

    return 0;
}

my $help = <<'HELP';
usage: sshca <command> [options] args...

  commands:
    init
    issue
    renew
    revoke
    history
    list
    cleanup
HELP

sub usage() {
}

if (@ARGV == 0 or $ARGV[0] eq 'help' or $ARGV[0] eq '--help') {
    usage();
    exit 0;
}

my %cmd = (
    init => \&cmd_init,
    issue => \&cmd_issue,
    renew => \&cmd_renew,
    revoke => \&cmd_revoke,
    history => \&cmd_history,
    list => \&cmd_list,
    cleanup => \&cmd_cleanup,
    );

my %common_opts = (
    'basedir=s' => \$options{basedir},
    'config=s'  => \$options{config},
    'debug'     => \$DEBUG,
    );

my %cmd_opts = (
    init => { 'upgrade'         => \$options{"upgrade"},
              'serial=i'        => \$options{serial},
              'import-hostca=s' => \$options{"import-hostca"},
              'import-userca=s' => \$options{"import-userca"},
              %common_opts, },
    issue => { 'host'        => sub { $options{certtype} = 'host' },
               'option=s'    => \@{$options{certoptions}},
               'principal=s' => \@{$options{certprincipals}},
               'validity=s'  => \$options{certvalidity},
               %common_opts },
    renew =>  { 'serial'      => sub { $options{renewal} = 'serial' },
                'fingerprint' => sub { $options{renewal} = 'fingerprint'; die "Fingerprint renewals are planned\n" },
                'identity'       => sub { $options{renewal} = 'identity'; },
                'new-identity=s' => \$options{new_identity},
                'validity=s'     => \$options{certvalidity},
                %common_opts },
    revoke => { 'serial'      => sub { $options{renewal} = 'serial' },
                'fingerprint' => sub { $options{renewal} = 'fingerprint'; die "Fingerprint renewals are planned\n" },
               'identity'    => sub { $options{renewal} = 'identity'; die "Identity renewals are planned\n" },
               'validity=s'  => \$options{certvalidity},
               %common_opts },
    history => { %common_opts },
    list    => { 'expiry=s'    => sub {
                      $options{expiry} = ($_[1] =~ s/[+]00:00$//r);
                 },
                 'issued'      => sub {
                     $options{states} = [ 'ISSUED' ];
                 },
                 %common_opts },
    cleanup => { 'dry-run' => \$options{"dry-run"},
                 %common_opts },
    );

Getopt::Long::Configure( 'require_order' );
GetOptionsFromArray(\@ARGV, %common_opts)
    or exit 1;
my $command = shift @ARGV;
if ($cmd{$command}) {
    configure();
    Getopt::Long::Configure( 'permute' );
    GetOptionsFromArray(\@ARGV, $cmd_opts{$command}->%*)
        or exit 1;
    exit $cmd{$command}->(@ARGV);
}
else {
    say "Unknown command: '$command'";
    usage();
    exit 1;
}


__END__

=head1 NAME

sshca - Minimalistic SSH Certificate Authority

=head1 VERSION

version 0.0.10

=head1 SYNOPSIS

  $ sshca init
  Successfully created SH CA directory ~/sshca
  $ sshca issue certName ~/.ssh/id_ed25519.pub
  User certificate with identity 'certName' and serial number 1:
  ... certificate data ...
  $ sshca renew 1
  ... certificate data ...

=head1 DESCRIPTION

This is a simple SSH Certificate Authority. SSH certificates greatly
enhance the functionality of SSH public keys. The C<sshca> script hands
out certificates for public keys and tracks these certs.

=head1 SEE ALSO

For documentation of the command line utility, see L<App::sshca>.

