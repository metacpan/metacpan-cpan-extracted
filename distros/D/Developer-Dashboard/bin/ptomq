#!/usr/bin/env perl

use strict;
use warnings;

use FindBin qw($Bin);
use lib "$Bin/../lib";

use Developer::Dashboard::CLI::Query qw(run_query_command);

# main(@ARGV)
# Runs the standalone TOML query executable.
# Input: command-line arguments from @ARGV and optional STDIN.
# Output: prints the selected TOML value, then exits.
run_query_command( command => 'ptomq', args => \@ARGV );

__END__

=pod

=head1 NAME

ptomq - standalone TOML query command for Developer Dashboard

=head1 SYNOPSIS

  ptomq [path] [file]

=head1 DESCRIPTION

This is the lightweight standalone executable behind C<dashboard ptomq>.

=cut
