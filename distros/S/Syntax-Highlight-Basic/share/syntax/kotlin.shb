[match:Special]
pattern: \v\@(author|constructor|receiver|return|since|suppress)>

[match:Identifier]
pattern: \v(\s|\[)\S+

[match:Error]
pattern: \v\\.

[match:Character]
pattern: \v'[^\\]'

[match:Identifier]
pattern: \v(\w)@<!\@[[:alnum:]_.]*(:[[:alnum:]_.]*)?

[match:Identifier]
pattern: \v\w+\@

[match:Identifier]
pattern: \v(\w)@<=\@\w+

[match:Identifier]
pattern: \v\$[a-zA-Z_]\w*

[match:Number]
pattern: \v<\d+[_[:digit:]]*(uL?|UL?|[LFf])?

[match:Number]
pattern: \v<0[Xx][0-9a-fA-F]+[_[:xdigit:]]*(uL?|UL?|L)?

[match:Number]
pattern: \v<0[Bb][01]+[_01]*(uL?|UL?|L)?

[match:Float]
pattern: \v<\d*(\d[eE][-+]?\d+|\.\d+([eE][-+]?\d+)?)[Ff]?

[match:Special]
pattern: !!

[match:Structure]
pattern: ->

