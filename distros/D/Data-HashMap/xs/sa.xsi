SV*
swap(SV* self_sv, SV* key_sv, SV* new_val)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        EXTRACT_STR_KEY(key_sv);
        void* old;
        SvREFCNT_inc(new_val);
        if (!hashmap_sa_swap(self, _kstr, (uint32_t)_klen, _khash, _kutf8, (void*)new_val, &old)) { SvREFCNT_dec(new_val); XSRETURN_UNDEF; }
        RETVAL = (SV*)old;
    OUTPUT:
        RETVAL


SV*
clone(SV* self_sv)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        HashMapSA* clone = hashmap_sa_clone(self);
        if (!clone) croak("Failed to clone");
        { size_t _i; for (_i = 0; _i < clone->capacity; _i++) {
            if (SA_NODE_LIVE(clone->nodes[_i]) && clone->nodes[_i].value)
                SvREFCNT_inc((SV*)clone->nodes[_i].value);
        } }
        RETVAL = sv_setref_pv(newSV(0), HvNAME(SvSTASH(SvRV(self_sv))), (void*)clone);
    OUTPUT:
        RETVAL

void
from_hash(SV* self_sv, SV* href)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        if (!SvROK(href) || SvTYPE(SvRV(href)) != SVt_PVHV)
            croak("from_hash requires a hashref");
        HV* hv = (HV*)SvRV(href);
        hashmap_sa_reserve(self, (size_t)HvUSEDKEYS(hv));
        hv_iterinit(hv);
        HE* he;
        while ((he = hv_iternext(hv))) {
            STRLEN klen; const char* kstr = HePV(he, klen);
            bool kutf8 = HeUTF8(he) ? true : false;
            uint32_t khash = hm_hash_string(kstr, (uint32_t)klen);
            SV* val = HeVAL(he);
            SvREFCNT_inc(val);
            if (!hashmap_sa_put(self, kstr, (uint32_t)klen, khash, kutf8, (void*)val, 0)) SvREFCNT_dec(val);
        }

void
merge(SV* self_sv, SV* other_sv)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        if (!SvROK(other_sv) || !SvOBJECT(SvRV(other_sv)) || SvSTASH(SvRV(other_sv)) != stash_sa)
            croak("Expected a Data::HashMap::SA object");
        HashMapSA* other = INT2PTR(HashMapSA*, SvIV(SvRV(other_sv)));
        hashmap_sa_reserve(self, self->size + other->size);
        uint32_t now = other->expires_at ? (uint32_t)time(NULL) : 0;
        size_t i;
        for (i = 0; i < other->capacity; i++) {
            if (SA_NODE_LIVE(other->nodes[i]) && !HM_TTL_SKIP_EXPIRED(other, i, now)) {
                SvREFCNT_inc((SV*)other->nodes[i].value);
                if (!hashmap_sa_put(self, other->nodes[i].key, HM_UNPACK_LEN(other->nodes[i].key_len), other->nodes[i].key_hash, HM_UNPACK_UTF8(other->nodes[i].key_len), (void*)other->nodes[i].value, 0)) SvREFCNT_dec((SV*)other->nodes[i].value);
            }
        }


SV*
to_hash(SV* self_sv)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        HV* hv = newHV();
        uint32_t now = self->expires_at ? (uint32_t)time(NULL) : 0;
        size_t i;
        for (i = 0; i < self->capacity; i++) {
            if (SA_NODE_LIVE(self->nodes[i]) && !HM_TTL_SKIP_EXPIRED(self, i, now)) {
                uint32_t klen = HM_UNPACK_LEN(self->nodes[i].key_len);
                bool kutf8 = HM_UNPACK_UTF8(self->nodes[i].key_len);
                SV* val = self->nodes[i].value ? SvREFCNT_inc((SV*)self->nodes[i].value) : &PL_sv_undef;
                (void)hv_store(hv, self->nodes[i].key, kutf8 ? -(I32)klen : (I32)klen, val, 0);
            }
        }
        RETVAL = newRV_noinc((SV*)hv);
    OUTPUT:
        RETVAL

bool
put_ttl(SV* self_sv, SV* key_sv, SV* value, UV ttl)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        EXTRACT_STR_KEY(key_sv);
        SvREFCNT_inc(value);
        RETVAL = hashmap_sa_put(self, _kstr, (uint32_t)_klen, _khash, _kutf8, (void*)value, (uint32_t)ttl);
        if (!RETVAL) SvREFCNT_dec(value);
    OUTPUT:
        RETVAL

SV*
get_or_set(SV* self_sv, SV* key_sv, SV* default_value)
    CODE:
        EXTRACT_MAP(HashMapSA, stash_sa, "Data::HashMap::SA", self_sv);
        EXTRACT_STR_KEY(key_sv);
        bool was_found;
        SvREFCNT_inc(default_value);
        size_t idx = hashmap_sa_get_or_set(self, _kstr, (uint32_t)_klen, _khash, _kutf8, (void*)default_value, 0, &was_found);
        if (idx >= self->capacity) {
            SvREFCNT_dec(default_value);
            XSRETURN_UNDEF;
        }
        if (was_found) SvREFCNT_dec(default_value);
        RETVAL = SvREFCNT_inc((SV*)self->nodes[idx].value);
    OUTPUT:
        RETVAL