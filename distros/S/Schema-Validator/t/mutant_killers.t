# ===========================================================================
# SECTION 6: COND_INV_505_4 -- if (-e $cache_file) inversion
#
# Source line 505:  if (-e $cache_file) {
# Mutation: unless (-e $cache_file)
#
# When the cache FILE DOES NOT EXIST and the network fails, the stale
# fallback must be SKIPPED.  Mutant would attempt stale read on a non-
# existent file, emitting "Could not read stale cache".
#
# Kill strategy: verify that "Could not read stale cache" is NOT emitted
# when the file does not exist.  Only "no vocabulary content" should appear.
# ===========================================================================

subtest 'COND_INV_505_4: stale fallback skipped when cache file absent' => sub {
	# Non-existent path -- -e returns false.
	# Network also fails -- no content from either source.
	# Mutant would enter the stale block, call _slurp_file on a missing file.

	my $nonexistent = '/no/such/file/mk_505_$$';

	my $fail_res = FakeResp->new(0, undef);
	my $g = mock_scoped(
		'LWP::UserAgent::new' => sub { bless {}, 'LWP::UserAgent' },
		'LWP::UserAgent::get' => sub { $fail_res },
	);

	my @warnings;
	local $SIG{__WARN__} = sub { push @warnings, $_[0] };

	my $result = load_dynamic_vocabulary(
		cache_file     => $nonexistent,
		cache_duration => 0,
	);

	# The stale-read carp must NOT appear when file is absent
	my $stale_err_seen = grep { /\Q$config{carp_stale}\E/i } @warnings;
	is($stale_err_seen, 0,
		'COND_INV_505_4: "Could not read stale cache" NOT emitted when file absent');

	# The "no content" carp MUST appear (normal no-content path)
	my $no_vocab_seen = grep { /\Q$config{carp_no_vocab}\E/i } @warnings;
	ok($no_vocab_seen,
		'COND_INV_505_4: "no vocabulary content available" IS emitted');

	is(scalar keys %$result, 0, 'COND_INV_505_4: returns empty hashref');

	diag "Warnings: " . join('; ', @warnings) if $ENV{TEST_VERBOSE};
};

# ===========================================================================
# SECTION 7: COND_INV_507_5 -- if ($@) inversion
#
# Source line 507:  if ($@) {
# Mutation: unless ($@)
#
# When stale-cache read SUCCEEDS ($@ is false):
#   Original: emit "Network unavailable; using stale cache"
#   Mutant: emit "Could not read stale cache" (wrong warning)
#
# When stale-cache read FAILS ($@ is true):
#   Original: emit "Could not read stale cache"
#   Mutant: emit "Network unavailable; using stale cache" (wrong warning)
#
# Kill strategies: test BOTH sub-paths and check which carp is emitted.
# ===========================================================================

subtest 'COND_INV_507_5 path A: stale read succeeds -> correct carp emitted' => sub {
	# Stale read succeeds: $@ is false.
	# Original: "Network unavailable; using stale cache" carp.
	# Mutant: "Could not read stale cache" carp (wrong!).

	my (undef, $path) = tempfile(UNLINK => 1);
	_write($path, $ANY_JSONLD);

	my $fail_res = FakeResp->new(0, undef);
	my $g = mock_scoped(
		'LWP::UserAgent::new' => sub { bless {}, 'LWP::UserAgent' },
		'LWP::UserAgent::get' => sub { $fail_res },
	);

	my @warnings;
	local $SIG{__WARN__} = sub { push @warnings, $_[0] };

	load_dynamic_vocabulary(
		cache_file     => $path,
		cache_duration => 0,
	);

	# "Network unavailable" MUST appear; "Could not read stale cache" must NOT
	my $net_warn   = grep { /\Q$config{carp_stale_ok}\E/i } @warnings;
	my $stale_warn = grep { /\Q$config{carp_stale}\E/i    } @warnings;

	ok( $net_warn,  'COND_INV_507_5A: "Network unavailable" emitted on stale success');
	is( $stale_warn, 0, 'COND_INV_507_5A: "Could not read stale" NOT emitted on stale success');

	diag "Warnings: " . join('; ', @warnings) if $ENV{TEST_VERBOSE};
};

subtest 'COND_INV_507_5 path B: stale read fails -> correct carp emitted' => sub {
	# Stale read throws: $@ is true.
	# Original: "Could not read stale cache" carp.
	# Mutant: "Network unavailable; using stale cache" carp (wrong!).

	my (undef, $path) = tempfile(UNLINK => 1);
	_write($path, 'placeholder');

	my $fail_res = FakeResp->new(0, undef);
	my $g = mock_scoped(
		'LWP::UserAgent::new' => sub { bless {}, 'LWP::UserAgent' },
		'LWP::UserAgent::get' => sub { $fail_res },
		'Schema::Validator::_slurp_file' => sub { die "stale read error\n" },
	);

	my @warnings;
	local $SIG{__WARN__} = sub { push @warnings, $_[0] };

	load_dynamic_vocabulary(
		cache_file     => $path,
		cache_duration => 0,
	);

	# "Could not read stale cache" MUST appear; "Network unavailable" must NOT
	my $stale_warn = grep { /\Q$config{carp_stale}\E/i    } @warnings;
	my $net_warn   = grep { /\Q$config{carp_stale_ok}\E/i } @warnings;

	ok( $stale_warn,  'COND_INV_507_5B: "Could not read stale" emitted when read fails');
	is( $net_warn, 0, 'COND_INV_507_5B: "Network unavailable" NOT emitted when read fails');

	diag "Warnings: " . join('; ', @warnings) if $ENV{TEST_VERBOSE};
};

