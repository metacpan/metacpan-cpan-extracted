sub sql_dashboard_parse_sql_blocks {
    my ( $sql_text, $sqls_sep, $instruction_sep ) = @_;
    my @blocks;
    for my $raw_block ( split /\Q$sqls_sep\E/s, $sql_text ) {
        next if !defined $raw_block;
