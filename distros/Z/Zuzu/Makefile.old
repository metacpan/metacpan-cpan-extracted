# --- MakeMaker processPL section:


# --- MakeMaker installbin section:

EXE_FILES = bin/zuzu-highlight.pl bin/zuzu-plackup.pl bin/zuzu-tidy.pl bin/zuzu.pl bin/zuzudoc.pl stdlib/scripts/zuzuprove stdlib/scripts/zuzuzoo

pure_all :: $(INST_SCRIPT)/zuzu-highlight.pl $(INST_SCRIPT)/zuzu-plackup.pl $(INST_SCRIPT)/zuzu-tidy.pl $(INST_SCRIPT)/zuzu.pl $(INST_SCRIPT)/zuzudoc.pl $(INST_SCRIPT)/zuzuprove $(INST_SCRIPT)/zuzuzoo
	$(NOECHO) $(NOOP)

realclean ::
	$(RM_F) \
	  $(INST_SCRIPT)/zuzu-highlight.pl $(INST_SCRIPT)/zuzu-plackup.pl \
	  $(INST_SCRIPT)/zuzu-tidy.pl $(INST_SCRIPT)/zuzu.pl \
	  $(INST_SCRIPT)/zuzudoc.pl $(INST_SCRIPT)/zuzuprove \
	  $(INST_SCRIPT)/zuzuzoo 

$(INST_SCRIPT)/zuzu-highlight.pl : bin/zuzu-highlight.pl $(FIRST_MAKEFILE) $(INST_SCRIPT)$(DFSEP).exists $(INST_BIN)$(DFSEP).exists
	$(NOECHO) $(RM_F) $(INST_SCRIPT)/zuzu-highlight.pl
	$(CP) bin/zuzu-highlight.pl $(INST_SCRIPT)/zuzu-highlight.pl
	$(FIXIN) $(INST_SCRIPT)/zuzu-highlight.pl
	-$(NOECHO) $(CHMOD) $(PERM_RWX) $(INST_SCRIPT)/zuzu-highlight.pl

$(INST_SCRIPT)/zuzu-plackup.pl : bin/zuzu-plackup.pl $(FIRST_MAKEFILE) $(INST_SCRIPT)$(DFSEP).exists $(INST_BIN)$(DFSEP).exists
	$(NOECHO) $(RM_F) $(INST_SCRIPT)/zuzu-plackup.pl
	$(CP) bin/zuzu-plackup.pl $(INST_SCRIPT)/zuzu-plackup.pl
	$(FIXIN) $(INST_SCRIPT)/zuzu-plackup.pl
	-$(NOECHO) $(CHMOD) $(PERM_RWX) $(INST_SCRIPT)/zuzu-plackup.pl

$(INST_SCRIPT)/zuzu-tidy.pl : bin/zuzu-tidy.pl $(FIRST_MAKEFILE) $(INST_SCRIPT)$(DFSEP).exists $(INST_BIN)$(DFSEP).exists
	$(NOECHO) $(RM_F) $(INST_SCRIPT)/zuzu-tidy.pl
	$(CP) bin/zuzu-tidy.pl $(INST_SCRIPT)/zuzu-tidy.pl
	$(FIXIN) $(INST_SCRIPT)/zuzu-tidy.pl
	-$(NOECHO) $(CHMOD) $(PERM_RWX) $(INST_SCRIPT)/zuzu-tidy.pl

$(INST_SCRIPT)/zuzu.pl : bin/zuzu.pl $(FIRST_MAKEFILE) $(INST_SCRIPT)$(DFSEP).exists $(INST_BIN)$(DFSEP).exists
	$(NOECHO) $(RM_F) $(INST_SCRIPT)/zuzu.pl
	$(CP) bin/zuzu.pl $(INST_SCRIPT)/zuzu.pl
	$(FIXIN) $(INST_SCRIPT)/zuzu.pl
	-$(NOECHO) $(CHMOD) $(PERM_RWX) $(INST_SCRIPT)/zuzu.pl

$(INST_SCRIPT)/zuzudoc.pl : bin/zuzudoc.pl $(FIRST_MAKEFILE) $(INST_SCRIPT)$(DFSEP).exists $(INST_BIN)$(DFSEP).exists
	$(NOECHO) $(RM_F) $(INST_SCRIPT)/zuzudoc.pl
	$(CP) bin/zuzudoc.pl $(INST_SCRIPT)/zuzudoc.pl
	$(FIXIN) $(INST_SCRIPT)/zuzudoc.pl
	-$(NOECHO) $(CHMOD) $(PERM_RWX) $(INST_SCRIPT)/zuzudoc.pl

$(INST_SCRIPT)/zuzuprove : stdlib/scripts/zuzuprove $(FIRST_MAKEFILE) $(INST_SCRIPT)$(DFSEP).exists $(INST_BIN)$(DFSEP).exists
	$(NOECHO) $(RM_F) $(INST_SCRIPT)/zuzuprove
	$(CP) stdlib/scripts/zuzuprove $(INST_SCRIPT)/zuzuprove
	$(FIXIN) $(INST_SCRIPT)/zuzuprove
