#!/usr/bin/perl
use strict;
use warnings;

our $VERSION = '2.000012';

BEGIN {
    return if $^C;

    @INC = split /;/, $ENV{T2_HARNESS_INCLUDES} if $ENV{T2_HARNESS_INCLUDES};

    require App::Yath::Script;

    App::Yath::Script::do_begin();
}

exit(App::Yath::Script::do_runtime());

__END__

=pod

=encoding UTF-8

=head1 NAME

yath - script to launch yath.

