        EXTRACT_NEW_ARGS(_max_size, _ttl, _lru_skip);
        HashMapSS* map = hashmap_ss_create(_max_size, _ttl, _lru_skip);
        if (!map) croak("Failed to create HashMap::SS");
        RETVAL = sv_setref_pv(newSV(0), class, (void*)map);
    OUTPUT:
        RETVAL

