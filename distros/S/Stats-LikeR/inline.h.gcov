        -: 1219:    assert(isREGEXP(re));
        -: 1220:
        -: 1221:    return SvTYPE(re) == SVt_PVLV ? p->xpv_len_u.xpvlenu_rx
        -: 1222:                                   : (struct regexp *)p;
        -: 1223:}
