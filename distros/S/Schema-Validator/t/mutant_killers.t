use warnings;

use FindBin qw($Bin);
# Under prove -t (taint mode) $Bin is tainted; detaint before use lib.
use lib (do {
	(my $d = $Bin) =~ /\A(.*)\z/s;
	("$1/../lib",
	 "$1/../../Test-Mockingbird/lib",
	 "$1/../../Test-Returns/lib");
});

use File::Temp     qw(tempfile);
use Test::Most;
use Test::Mockingbird;
use Test::Returns;
use Test::Warn;

use Schema::Validator qw(is_valid_datetime load_dynamic_vocabulary);

# ===========================================================================
# CONSTANTS
# ===========================================================================

use Readonly;

# Cache class/property labels in the two JSON-LD fixtures used for
# freshness tests so results distinguish "loaded from cache" vs "fetched".
Readonly::Scalar my $CACHE_CLASS => 'CacheHit';
Readonly::Scalar my $FETCH_CLASS => 'FetchHit';

# JSON-LD for the cache file (fresh-path tests read this).
Readonly::Scalar my $CACHE_JSONLD =>
	'{"@graph":[{"@type":"rdfs:Class","rdfs:label":"' . $CACHE_CLASS . '",'
	. '"@id":"https://schema.org/' . $CACHE_CLASS . '"}]}';

# JSON-LD returned by the mock HTTP fetch (stale-path tests get this).
Readonly::Scalar my $FETCH_JSONLD =>
	'{"@graph":[{"@type":"rdfs:Class","rdfs:label":"' . $FETCH_CLASS . '",'
	. '"@id":"https://schema.org/' . $FETCH_CLASS . '"}]}';

# Minimal valid JSON-LD used when the specific content doesn't matter.
Readonly::Scalar my $ANY_JSONLD =>
	'{"@graph":[{"@type":"rdfs:Class","rdfs:label":"Thing",'
	. '"@id":"https://schema.org/Thing"}]}';

# Duration (seconds) used for boundary tests.
Readonly::Scalar my $CACHE_DURATION => 100;

# Number of seconds before "now" that makes a file clearly fresh.
Readonly::Scalar my $FRESH_AGE => 10;

# Number of seconds before "now" that makes a file clearly stale.
Readonly::Scalar my $STALE_AGE => 200;

# ===========================================================================
# CONFIGURATION -- all magic strings/numbers go here.
# ===========================================================================

my %config = (
	# Valid date input used when the value doesn't matter
	valid_date   => '2025-06-28',

	# Carps emitted on various error paths
	carp_read    => 'Could not read cache',
	carp_write   => 'Could not write cache',
	carp_stale   => 'Could not read stale cache',
	carp_stale_ok => 'Network unavailable; using stale cache',
	carp_no_vocab => 'no vocabulary content available',
	carp_parse   => 'Failed to parse vocabulary JSON',
	carp_not_obj => 'Vocabulary JSON is not a JSON object',
	carp_no_graph => "Vocabulary JSON is missing the '\@graph' array",

	# Expected exact return value from _spit_file
	spit_return  => 1,

	# ua_timeout values for the arg-handling test
	config_timeout => 30,
	custom_timeout => 99,
);

# ===========================================================================
# HELPERS
# ===========================================================================

{
	# Minimal HTTP response stand-in for LWP mocking.
	package FakeResp;
	sub new             { bless { ok => $_[1], body => $_[2] }, $_[0] }
	sub is_success      { $_[0]->{ok}   }
	sub decoded_content { $_[0]->{body} }
	sub status_line     { $_[0]->{ok} ? '200 OK' : '503 Unavailable' }
}

# Write content to a file path without using module internals.
sub _write { open my $fh, '>', $_[0] or die $!; print $fh $_[1]; close $fh }

# Create a temp file and set its mtime to exactly $age seconds in the past.
sub _aged_tempfile {
	my ($age, $content) = @_;
	my (undef, $path) = tempfile(UNLINK => 1);
	_write($path, $content // $CACHE_JSONLD);
	my $target = time() - $age;
	utime($target, $target, $path);
	return $path;
}

# ===========================================================================
# SECTION 1: is_valid_datetime -- BOOL_NEGATE_297_2 and RETURN_UNDEF_297_2
#
# Source line 297:  return 0 unless defined $string && length $string;
#
# Mutations:
#   BOOL_NEGATE: return !0 = 1  when string is undef/empty   (wrong: should be 0)
#   RETURN_UNDEF: return undef  when string is undef/empty   (wrong: should be 0)
#
# Kill strategy: assert return is EXACTLY the integer 0 (not 1, not undef).
# ===========================================================================

subtest 'BOOL_NEGATE_297_2 + RETURN_UNDEF_297_2: undef input returns exactly 0' => sub {
	# Mutant would return 1 (negated 0) or undef; real code must return 0.
	# Using a mock so the parser is never reached for this degenerate input.

	my $g = mock_scoped 'DateTime::Format::ISO8601::parse_datetime'
		=> sub { fail 'parser must not be called for undef input'; return };

	my $result = is_valid_datetime(undef);

	# is() checks both value AND defined-ness via string comparison
	is($result, 0, 'undef input returns integer 0 (not 1 or undef)');

	# Explicitly confirm it is defined (kills RETURN_UNDEF mutation)
	ok(defined($result), 'undef input: return value is defined');

	# Confirm it is false (kills BOOL_NEGATE mutation -- negation gives true)
	ok(!$result, 'undef input: return value is false');

	diag "is_valid_datetime(undef) = $result" if $ENV{TEST_VERBOSE};
};

subtest 'BOOL_NEGATE_297_2 + RETURN_UNDEF_297_2: empty string returns exactly 0' => sub {
	# Same mutations applied to the empty-string guard case.

	my $g = mock_scoped 'DateTime::Format::ISO8601::parse_datetime'
		=> sub { fail 'parser must not be called for empty string'; return };

	my $result = is_valid_datetime('');

	is($result,       0, 'empty string returns integer 0');
	ok( defined($result), 'empty string: return value is defined');
	ok(!$result,          'empty string: return value is false');
};

# ===========================================================================
# SECTION 2: COND_INV_468_2 -- if(scalar(@_)) inversion
#
# Source line 468:  if(scalar(@_)) {
# Mutation: unless(scalar(@_))
#
# With the mutant, validation runs ONLY when @_ is EMPTY.  When args ARE
# supplied, $params stays undef and all four parameters fall back to
# %config defaults, ignoring the caller-supplied values.
#
# Kill strategy: pass a custom ua_timeout; spy to confirm that exact value
# reaches LWP::UserAgent->new (not the 30-second default).
# ===========================================================================

subtest 'COND_INV_468_2: per-call args override config when @_ is non-empty' => sub {
	# Mutant (unless scalar @_) skips validation/assignment when args present,
	# so $params stays undef and all args fall back to %config defaults.

	my $captured_timeout;
	my $ok_res = FakeResp->new(1, $ANY_JSONLD);

	my $g = mock_scoped(
		'LWP::UserAgent::new' => sub {
			my (undef, %opts) = @_;
			$captured_timeout = $opts{timeout};
			return bless {}, 'LWP::UserAgent';
		},
		'LWP::UserAgent::get' => sub { $ok_res },
		'Schema::Validator::_spit_file' => sub { 1 },
	);

	local $SIG{__WARN__} = sub {};

	# Override the config default so it differs from our custom value
	local $Schema::Validator::config{ua_timeout} = $config{config_timeout};

	load_dynamic_vocabulary(
		cache_file     => '/tmp/_mk_cond468_$$.jsonld',
		cache_duration => 0,
		ua_timeout     => $config{custom_timeout},
	);

	# Must be 99 (our custom value), not 30 (the config default).
	# If mutant inverts the if, $params is never set, timeout falls to 30.
	is($captured_timeout, $config{custom_timeout},
		'per-call ua_timeout reaches LWP when @_ is non-empty (if not unless)');

	diag "Captured timeout: $captured_timeout" if $ENV{TEST_VERBOSE};
};

# ===========================================================================
# SECTION 3: NUM_BOUNDARY_490_55_> (HIGH) -- freshness comparison mutations
#
# Source line 490:
#   if (-e $cache_file && (time - (stat($cache_file))[9] < $cache_duration))
#
# Mutations (4 variants):
#   A. < to >    : treats STALE files as fresh, FRESH files as stale
#   B. < to <=   : boundary flip -- exact-age file treated as fresh
#   C. < to >=   : treats STALE (or equal) files as fresh
#   D. if to unless : completely inverts the entire condition
#
# Kill strategies:
#   Test 1 -- CLEARLY FRESH file + large duration:
#     time-mtime=10, duration=100 -> 10 < 100 = TRUE (no fetch)
#     Mutant A (>): 10 > 100 = FALSE -> fetch -> KILLED
#     Mutant C (>=): 10 >= 100 = FALSE -> fetch -> KILLED
#     Mutant D (unless): inverted -> fetch -> KILLED
#
#   Test 2 -- FILE AT EXACT BOUNDARY:
#     time-mtime=100, duration=100 -> 100 < 100 = FALSE (stale, fetch)
#     Mutant B (<=): 100 <= 100 = TRUE -> no fetch -> KILLED
#     Mutant C (>=): 100 >= 100 = TRUE -> no fetch -> KILLED
# ===========================================================================

subtest 'NUM_BOUNDARY_490_55_> Test1: fresh file uses cache (kills >, >=, unless)' => sub {
	# File is FRESH_AGE (10s) old.  With duration=CACHE_DURATION (100s):
	# time - mtime = 10 < 100 = TRUE -> use cache, no HTTP fetch.
	# Any mutation that flips or inverts this makes it FALSE -> fetch happens.

	# CACHE_JSONLD in file, FETCH_JSONLD from LWP -- they have different class names
	my $path = _aged_tempfile($FRESH_AGE, $CACHE_JSONLD);

	my $fetch_count = 0;
	my $g = mock_scoped(
		'LWP::UserAgent::new' => sub { bless {}, 'LWP::UserAgent' },
		'LWP::UserAgent::get' => sub {
			$fetch_count++;
			FakeResp->new(1, $FETCH_JSONLD);
		},
	);

	local $SIG{__WARN__} = sub {};
	my $result = load_dynamic_vocabulary(
		cache_file     => $path,
		cache_duration => $CACHE_DURATION,
	);

	# Must have used the cache, not fetched: CacheHit present, FetchHit absent
	is($fetch_count, 0, 'NUM_BOUNDARY Test1: no HTTP fetch for clearly-fresh cache');
	ok( exists $result->{$CACHE_CLASS},
		'NUM_BOUNDARY Test1: cache class present in result (cache was used)');
	ok(!exists $result->{$FETCH_CLASS},
		'NUM_BOUNDARY Test1: fetch class absent (no fetch happened)');

	diag "fetch_count=$fetch_count, result keys: " . join(',', sort keys %$result)
		if $ENV{TEST_VERBOSE};
};

subtest 'NUM_BOUNDARY_490_55_> Test2: exact-boundary file is STALE (kills <=, >=)' => sub {
	# File mtime is set to exactly CACHE_DURATION seconds ago.
	# time - mtime = 100, duration = 100
	# Original (< ): 100 < 100 = FALSE -> stale -> fetch must happen
	# Mutant <= : 100 <= 100 = TRUE -> fresh -> no fetch -> KILLED
	# Mutant >= : 100 >= 100 = TRUE -> fresh -> no fetch -> KILLED

	my $path = _aged_tempfile($CACHE_DURATION, $CACHE_JSONLD);

	my $fetch_count = 0;
	my $g = mock_scoped(
		'LWP::UserAgent::new' => sub { bless {}, 'LWP::UserAgent' },
		'LWP::UserAgent::get' => sub {
			$fetch_count++;
			FakeResp->new(1, $FETCH_JSONLD);
		},
		'Schema::Validator::_spit_file' => sub { 1 },
	);

	local $SIG{__WARN__} = sub {};
	my $result = load_dynamic_vocabulary(
		cache_file     => $path,
		cache_duration => $CACHE_DURATION,
	);

	# Must have fetched: file at exactly the duration boundary is STALE
	ok($fetch_count > 0,
		'NUM_BOUNDARY Test2: fetch occurs when file age equals cache_duration (stale)');
	ok(!exists $result->{$CACHE_CLASS},
		'NUM_BOUNDARY Test2: cache class absent (cache was not used)');
	ok( exists $result->{$FETCH_CLASS},
		'NUM_BOUNDARY Test2: fetch class present (fetch occurred)');

	diag "fetch_count=$fetch_count, result keys: " . join(',', sort keys %$result)
		if $ENV{TEST_VERBOSE};
};

