#!/usr/bin/env perl

use strict;
use warnings;

use File::Find;
use App::Test::Generator::LCSAJ;

my @modules;

find(
	sub {
		return unless /\.pm$/;

		push @modules, $File::Find::name;
	}, 'lib'
);

die 'No modules found under lib/' unless @modules;

for my $file (@modules) {
	print "Instrumenting $file\n";

	App::Test::Generator::LCSAJ::instrument_file($file);
}

print "\nDone.\n";
