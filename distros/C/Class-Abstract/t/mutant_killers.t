# ===========================================================================
# MUTANTS: BOOL_NEGATE_517_2 and RETURN_UNDEF_517_2
#
# Source:   return 0 unless defined $class;   (line 517 in _is_direct_abstract)
#
# BOOL_NEGATE_517_2 -- return 0 changed to: return 1
#   Effect: _is_direct_abstract(undef) returns 1 instead of 0.
#   Consequence: new(undef) would bypass the defined-guard and hit the
#   abstract check instead, croaking with the WRONG error message.
#
# RETURN_UNDEF_517_2 -- return 0 changed to: return undef
#   Effect: _is_direct_abstract(undef) returns undef instead of 0.
#   Consequence: 'if undef' is still false so enforcement doesn't fire,
#   but the exact return value changes from 0 to undef.
#
# Killer strategy: call the private helper directly with undef and assert
# the return value is EXACTLY the integer 0 (not 1, not undef).
# ===========================================================================

subtest 'BOOL_NEGATE_517_2 + RETURN_UNDEF_517_2 killers -- _is_direct_abstract(undef) = 0' => sub {
	plan tests => 3;

	diag '_is_direct_abstract(undef) must return exactly 0' if $ENV{TEST_VERBOSE};

	my $result = Class::Abstract::_is_direct_abstract(undef);

	diag "result = " . (defined $result ? $result : 'undef') if $ENV{TEST_VERBOSE};

	# BOOL_NEGATE: if return 1, is(1,0) fails -- kills the mutant
	# RETURN_UNDEF: if return undef, is('',0) ('' ne '0') fails -- kills the mutant
	is $result, $ZERO,
		'_is_direct_abstract(undef) returns exactly 0 (not 1, not undef)';

	# Verify integer type via Test::Returns (catches undef vs 0 difference)
	returns_ok $result, $config{schema_integer},
		'_is_direct_abstract(undef) satisfies integer return schema';

	# Confirm it is defined (undef return would fail this)
	ok defined($result),
		'_is_direct_abstract(undef) return value is defined (not undef)';
};

# ===========================================================================
# MUTANTS: BOOL_NEGATE_520_2 and RETURN_UNDEF_520_2
#
# Source:   return 1 if $class eq $SELF;   (line 520 in _is_direct_abstract)
#
# BOOL_NEGATE_520_2 -- return 1 changed to: return 0
#   Effect: _is_direct_abstract('Class::Abstract') returns 0 instead of 1.
#   Consequence: Class::Abstract itself could be instantiated directly!
#
# RETURN_UNDEF_520_2 -- return 1 changed to: return undef
#   Effect: _is_direct_abstract('Class::Abstract') returns undef instead of 1.
#   Consequence: 'if undef' is false, so enforcement does not fire for $SELF.
#
# Killer strategy:
#   1. _is_direct_abstract('Class::Abstract') must return exactly 1.
#   2. new('Class::Abstract') with enforcement on must croak.
# ===========================================================================

subtest 'BOOL_NEGATE_520_2 + RETURN_UNDEF_520_2 killers -- _is_direct_abstract(Class::Abstract) = 1' => sub {
	plan tests => 4;

	diag '_is_direct_abstract("Class::Abstract") must return exactly 1' if $ENV{TEST_VERBOSE};

	my $result = Class::Abstract::_is_direct_abstract($config{pkg_module});

	diag "result = " . (defined $result ? $result : 'undef') if $ENV{TEST_VERBOSE};

	# BOOL_NEGATE: if return 0, is(0,1) fails -- kills the mutant
	# RETURN_UNDEF: if return undef, is('',1) ('' ne '1') fails -- kills the mutant
	is $result, $ONE,
		'_is_direct_abstract("Class::Abstract") returns exactly 1 (not 0, not undef)';

	# Integer schema confirms return is a proper integer, not undef
	returns_ok $result, $config{schema_integer},
		'_is_direct_abstract("Class::Abstract") satisfies integer return schema';

	ok defined($result),
		'_is_direct_abstract("Class::Abstract") is defined (not undef)';

	# End-to-end: Class::Abstract itself must NOT be directly instantiable.
	# With BOOL_NEGATE or RETURN_UNDEF, _is_direct_abstract returns falsy for $SELF,
	# so the croak is never reached and this test would PASS (lives) when it should FAIL.
	enforcement_on {
		throws_ok { Class::Abstract::new($config{pkg_module}) }
			qr/Cannot instantiate abstract class Class::Abstract directly/,
			'new("Class::Abstract") croaks (mutant 0/undef return would suppress this)';
	};
};

# ===========================================================================
# COMBINED REGRESSION: all mutants at once
#
# A final integration subtest that exercises the full call chain end-to-end.
# If any mutant above survived, at least one of these assertions would fail.
# ===========================================================================

subtest 'combined regression -- all mutants, full call chain' => sub {
	plan tests => 6;

	diag 'Regression: combining all mutant killer scenarios' if $ENV{TEST_VERBOSE};

	# 1. String invocant on concrete class must succeed (COND_INV_342 + 414 killers)
	lives_ok { MK::Concrete->new() }
		'concrete class-name invocant succeeds (kills COND_INV_342_2 and 414_2 if mutated)';

	# 2. Unblessed ref must croak (COND_INV_342 killer)
	throws_ok { Class::Abstract::new([]) }
		$config{err_new_unblessed},
		'unblessed ref to new() croaks (kills COND_INV_342_2 if mutated)';

	# 3. BYPASS=1 suppresses enforcement (COND_INV_352 + 423 killers)
	{
		local $Class::Abstract::BYPASS                 = 1;
		local $Class::Abstract::config{harness_bypass} = 0;
		local $ENV{HARNESS_ACTIVE}                     = 0;
		lives_ok { MK::Abstract->new() }
			'BYPASS=1 suppresses enforcement (kills COND_INV_352_2 and 423_2 if mutated)';
	}

	# 4. No bypass fires enforcement (COND_INV_352 + 423 killers)
	enforcement_on {
		throws_ok { MK::Abstract->new() }
			$config{err_abstract},
			'no bypass fires enforcement (kills COND_INV_352_2 and 423_2 if mutated)';
	};

	# 5. _is_direct_abstract(undef) = 0, not 1 or undef (BOOL_NEGATE/RETURN_UNDEF 517 killers)
	is Class::Abstract::_is_direct_abstract(undef), $ZERO,
		'_is_direct_abstract(undef) is 0 (kills BOOL_NEGATE_517_2 and RETURN_UNDEF_517_2)';

	# 6. _is_direct_abstract('Class::Abstract') = 1, not 0 or undef (BOOL_NEGATE/RETURN_UNDEF 520 killers)
	is Class::Abstract::_is_direct_abstract($config{pkg_module}), $ONE,
		'_is_direct_abstract("Class::Abstract") is 1 (kills BOOL_NEGATE_520_2 and RETURN_UNDEF_520_2)';
};

done_testing;
