#!/usr/bin/perl
# t/mutant_killers.t -- tests designed to kill surviving mutants from
# xt/mutant_20260611_120738.t (generated by App::Test::Generator).
#
# Each subtest targets a specific mutation and contains assertions that:
#   - PASS with the original code
#   - FAIL with the mutated code
#
# Mutants targeted:
#   COND_INV_342_2  -- new():              if(ref) -> unless(ref)
#   COND_INV_352_2  -- new():              unless(bypass) -> if(bypass)
#   COND_INV_414_2  -- check_abstract():   if(ref) -> unless(ref)
#   COND_INV_423_2  -- check_abstract():   unless(bypass) -> if(bypass)
#   BOOL_NEGATE_517_2 -- _is_direct_abstract(): return 0 -> return 1  (undef case)
#   BOOL_NEGATE_520_2 -- _is_direct_abstract(): return 1 -> return 0  ($SELF case)
#   RETURN_UNDEF_517_2 -- _is_direct_abstract(): return 0 -> return undef (undef case)
#   RETURN_UNDEF_520_2 -- _is_direct_abstract(): return 1 -> return undef ($SELF case)

use strict;
use warnings;

use Readonly;
use Scalar::Util qw(blessed);
use Test::Most;
use Test::Returns;

use Class::Abstract;

# ---------------------------------------------------------------------------
# Configuration -- all constants in one place to avoid magic strings
# ---------------------------------------------------------------------------

my %config = (
	# Fixture package names (MK:: prefix avoids collision with other test files)
	pkg_abstract => 'MK::Abstract',
	pkg_concrete => 'MK::Concrete',
	pkg_module   => 'Class::Abstract',

	# Exact error patterns from the module POD
	err_abstract     => qr/Cannot instantiate abstract class \S+ directly/,
	err_new_unblessed => qr/new\(\) invocant must be a class name or blessed object, got/,
	err_chk_unblessed => qr/check_abstract\(\) requires a class name or blessed object/,

	# Test::Returns schemas for exact return type verification
	schema_integer => { type => 'integer' },
	schema_undef   => { type => 'undef'   },
);

# Exact integer values -- using named constants to make intent clear
Readonly::Scalar my $ZERO => 0;
Readonly::Scalar my $ONE  => 1;

# ---------------------------------------------------------------------------
# Fixture packages
# ---------------------------------------------------------------------------

# MK::Abstract: directly abstract via use parent
{
	package MK::Abstract;
	use parent -norequire, 'Class::Abstract';
}

# MK::Concrete: concrete subclass -- inherits via @ISA, provides own new()
{
	package MK::Concrete;
	our @ISA = ('MK::Abstract');
	sub new { my ($class) = @_; return $class->SUPER::new() }
}

diag 'Mutant killer tests for Class::Abstract' if $ENV{TEST_VERBOSE};

# ---------------------------------------------------------------------------
# Helper: disable all bypass paths so enforcement fires inside a harness
# ---------------------------------------------------------------------------

sub enforcement_on (&) {
	my ($code) = @_;
	local $Class::Abstract::BYPASS                 = 0;
	local $Class::Abstract::config{harness_bypass} = 0;
	local $ENV{HARNESS_ACTIVE}                     = 0;
	return $code->();
}

# ===========================================================================
# MUTANT: COND_INV_342_2
#
# Source:   if (ref $class) { croak unless blessed; $class = ref($class) }
# Mutation: unless (ref $class) { ... }   <-- condition INVERTED
#
# Effect of mutation:
#   The ref-check block fires for NON-references (plain strings) instead of
#   references.  For a plain string like 'MK::Concrete':
#     - blessed('MK::Concrete') = undef -> CROAK (wrong!)
#   For an unblessed ref like []:
#     - Block skipped; falls through without the "got ARRAY" croak (wrong!)
#
# Killer strategy:
#   1. A class-name string as invocant must SUCCEED (mutant would croak it).
#   2. An unblessed ref must croak with the exact "got TYPE" message
#      (mutant would skip the message and either succeed or give a different error).
# ===========================================================================

subtest 'COND_INV_342_2 killer -- new(): if(ref) vs unless(ref)' => sub {
	plan tests => 5;

	diag 'Testing ref-condition direction in new()' if $ENV{TEST_VERBOSE};

	# --- Killer 1: class-name string invocant must SUCCEED ---
	# With original (if ref): ref('MK::Concrete') = '' -> condition FALSE -> skip block -> ok
	# With mutant (unless ref): ref('MK::Concrete') = '' -> condition TRUE -> blessed fails -> CROAK
	my $obj;
	lives_ok { $obj = MK::Concrete->new() }
		'COND_INV_342_2: class-name string invocant lives (mutant would croak it)';

	ok blessed($obj), 'returned object is blessed (mutation would have prevented this)';

	is ref($obj), $config{pkg_concrete},
		'object is blessed into the correct concrete class';

	# --- Killer 2: unblessed ref invocant must croak with exact "got TYPE" message ---
	# With original (if ref): ref([]) = 'ARRAY' -> condition TRUE -> blessed fails -> CROAK "got ARRAY"
	# With mutant (unless ref): ref([]) = 'ARRAY' -> condition FALSE -> block skipped -> no "got ARRAY" croak
	throws_ok { Class::Abstract::new([]) }
		qr/new\(\) invocant must be a class name or blessed object, got ARRAY/,
		'COND_INV_342_2: unblessed ref croaks with exact "got ARRAY" message (mutant skips this)';

	# Also verify a HASH ref gives "got HASH" (not "got ARRAY") to confirm type-name precision
	throws_ok { Class::Abstract::new({}) }
		qr/new\(\) invocant must be a class name or blessed object, got HASH/,
		'COND_INV_342_2: unblessed hashref croaks with exact "got HASH" message';
};

# ===========================================================================
# MUTANT: COND_INV_352_2
#
# Source:   unless ($BYPASS || ($config{harness_bypass} && $ENV{HARNESS_ACTIVE})) {
#               croak if _is_direct_abstract($class);
#           }
# Mutation: if ($BYPASS || ...) { croak if ... }   <-- unless INVERTED to if
#
# Effect of mutation:
#   Enforcement fires WHEN bypass is active, and is SUPPRESSED when no bypass.
#   - $BYPASS=1 -> enforcement FIRES (wrong! should bypass)
#   - No bypass  -> enforcement SUPPRESSED (wrong! should fire)
#
# Killer strategy:
#   1. BYPASS=1 on abstract class -> lives (mutant would make it croak)
#   2. No bypass, abstract class  -> croaks (mutant would make it live)
# ===========================================================================

subtest 'COND_INV_352_2 killer -- new(): unless(bypass) vs if(bypass)' => sub {
	plan tests => 3;

	diag 'Testing bypass-condition direction in new()' if $ENV{TEST_VERBOSE};

	# --- Killer 1: $BYPASS=1 must SUPPRESS the croak ---
	# Original (unless bypass): bypass active -> condition FALSE -> skip croak -> LIVES
	# Mutant (if bypass):        bypass active -> condition TRUE  -> CROAK (wrong!)
	{
		local $Class::Abstract::BYPASS                 = 1;
		local $Class::Abstract::config{harness_bypass} = 0;
		local $ENV{HARNESS_ACTIVE}                     = 0;

		my $obj;
		lives_ok { $obj = MK::Abstract->new() }
			'COND_INV_352_2: BYPASS=1 suppresses croak (mutant would fire it)';
	}

	# --- Killer 2: no bypass must FIRE the croak ---
	# Original (unless bypass): bypass inactive -> condition TRUE -> CROAK
	# Mutant (if bypass):        bypass inactive -> condition FALSE -> no croak (wrong!)
	enforcement_on {
		throws_ok { MK::Abstract->new() }
			$config{err_abstract},
			'COND_INV_352_2: no bypass fires enforcement (mutant would suppress it)';
	};

	# --- Killer 3: concrete class must still succeed (bypass direction only affects abstract) ---
	enforcement_on {
		lives_ok { MK::Concrete->new() }
			'COND_INV_352_2: concrete class unaffected regardless of bypass direction';
	};
};

# ===========================================================================
# MUTANT: COND_INV_414_2
#
# Source:   if (ref $class) { croak unless blessed; $class = ref($class) }
#           in check_abstract()
# Mutation: unless (ref $class) { ... }   <-- condition INVERTED
#
# Same analysis as COND_INV_342_2 but applied to check_abstract().
# Killer strategy: mirror the new() killers.
# ===========================================================================

subtest 'COND_INV_414_2 killer -- check_abstract(): if(ref) vs unless(ref)' => sub {
	plan tests => 4;

	diag 'Testing ref-condition direction in check_abstract()' if $ENV{TEST_VERBOSE};

	# --- Killer 1: class-name string must NOT produce the "unblessed" croak ---
	# Original (if ref): ref('MK::Concrete') = '' -> skip block -> no wrong croak
	# Mutant (unless ref): ref('MK::Concrete') = '' -> enter block -> blessed fails -> CROAK
	enforcement_on {
		lives_ok { Class::Abstract::check_abstract($config{pkg_concrete}) }
			'COND_INV_414_2: class-name string invocant lives (mutant would croak it)';
	};

	# --- Killer 2: unblessed ref must croak with exact error ---
	# Original (if ref): ref([]) = 'ARRAY' -> TRUE -> enters block -> blessed fails -> CROAK
	# Mutant (unless ref): ref([]) = 'ARRAY' -> FALSE -> skips block -> no "unblessed" croak
	throws_ok { Class::Abstract::check_abstract([]) }
		$config{err_chk_unblessed},
		'COND_INV_414_2: unblessed arrayref croaks with documented error (mutant skips this)';

	throws_ok { Class::Abstract::check_abstract({}) }
		$config{err_chk_unblessed},
		'COND_INV_414_2: unblessed hashref also croaks with documented error';

	# --- Killer 3: blessed concrete object invocant must NOT croak ---
	# If the ref check is inverted, a blessed object (which IS a ref) would SKIP the
	# block, and its string form would hit the abstract check instead.
	my $concrete_obj = MK::Concrete->new();
	enforcement_on {
		lives_ok { Class::Abstract::check_abstract($concrete_obj) }
			'COND_INV_414_2: blessed concrete object passes (mutant would skip class extraction)';
	};
};

# ===========================================================================
