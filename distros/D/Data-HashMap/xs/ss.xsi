swap(SV* self_sv, SV* key_sv, SV* new_sv)
    CODE:
        EXTRACT_MAP(HashMapSS, stash_ss, "Data::HashMap::SS", self_sv);
        EXTRACT_STR_KEY(key_sv);
        STRLEN _nvl; const char* _nvs = SvPV(new_sv, _nvl); bool _nvu = SvUTF8(new_sv) ? true : false;
        const char* old; uint32_t old_len; bool old_utf8;
        if (!hashmap_ss_swap(self, _kstr, (uint32_t)_klen, _khash, _kutf8, _nvs, (uint32_t)_nvl, _nvu, &old, &old_len, &old_utf8)) XSRETURN_UNDEF;
        RETVAL = newSVpvn(old, old_len);
        if (old_utf8) SvUTF8_on(RETVAL);
        free((void*)old);
    OUTPUT:
        RETVAL


