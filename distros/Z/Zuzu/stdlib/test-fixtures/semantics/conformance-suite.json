			"mode": "result",
			"file": "conf-runtime-path-operators-first-fanout.zzs",
			"source": "function __fixture_result () {\n\tlet payload := { users: [ { name: \"Ada\" }, { name: \"Lin\" } ] };\n\tlet first := payload @ \"/users/#0/name\";\n\tlet all := payload @@ \"/users/*/name\";\n\treturn first _ \":\" _ all.length();\n}\n",
