# NAME

AnyEvent::Impl::Prima - Prima event loop adapter for AnyEvent

# SYNOPSIS

    use Prima;
    use AnyEvent::Impl::Prima;

    my $mw = Prima::MainWindow->new();

    my $timer = AnyEvent->timer(
        after => 10,
        cb => sub { $mw->close; },
    );

    Prima->run;

