[match:Special]
pattern: \bput\s+#\b

[match:Special]
pattern: \bopen\b

[match:Function]
pattern: \bend\s+function\b

[match:Function]
pattern: \bend\s+sub\b

[match:Function]
pattern: \bend\s+constructor\b

[match:Function]
pattern: \bend\s+destructor\b

[match:Function]
pattern: \bend\s+operator\b

[match:Function]
pattern: \bend\s+property\b

[match:Function]
pattern: \bpalette\s+get\b

[match:Special]
pattern: \bend\s+extern\b

[match:Special]
pattern: \bend\s+namespace\b

[match:Special]
pattern: #\d+

[match:Special]
pattern: #[a-zA-Z][[:alpha:].]*[%&!#]?

[match:PreProc]
pattern: #\s*assert\b

[match:PreProc]
pattern: #\s*cmdline\b

[match:PreProc]
pattern: #\s*error\b

[match:PreProc]
pattern: #\s*lang\b

[match:PreProc]
