    while ( my $entry = readdir $dh ) {
        next if $entry eq '.' || $entry eq '..';
        next if $entry !~ /\.json\z/;
        my $path = File::Spec->catfile( $dir, $entry );
        next if !-f $path;
        eval {
            sql_dashboard_secure_file($path);
            open my $fh, '<', $path or die "Unable to read $path: $!";
