        ["\x87\x8E",'keis83','cp932',{'INPUT_LAYOUT'=>'D'},"\x72\xF6"], # ㍽ 878E 72F6
        ["\x87\x8F",'keis83','cp932',{'INPUT_LAYOUT'=>'D'},"\x72\xF7"], # ㍼ 878F 72F7
