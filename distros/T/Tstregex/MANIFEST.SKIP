# --- Version Control Systems ---
\.git/
\.gitignore

# --- Build and Compilation Artifacts ---
^Makefile$
^Makefile.old$
^blib/
^pm_to_blib$
^MYMETA\..*$

# --- Local Workspace Scories (Development folders) ---
^none/
^bin/

# --- Linux/Cygwin Proxy Binary ---
# This is generated by Makefile.PL, so we don't include it in the dist
^tstregex$

# --- Temporary and Backup Files ---
\.bak$
\.tmp$
\.gz$

# --- MISC
^fails\.sh$
