    $collection->{info}{schema} ||= 'https://schema.getpostman.com/json/collection/v2.1.0/collection.json';
    $collection->{item} = [] if ref( $collection->{item} ) ne 'ARRAY';
    $collection->{variable} = [] if ref( $collection->{variable} ) ne 'ARRAY';
