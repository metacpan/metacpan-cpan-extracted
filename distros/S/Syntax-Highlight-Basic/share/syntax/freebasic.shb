[match:String]
pattern: \bspace\$

[match:String]
pattern: \bchr\$

[match:String]
pattern: \bspace\b\$?

[match:String]
pattern: \bchr\b\$?

[match:String]
pattern: \btrim\b\$?

[match:Statement]
pattern: \bline\s+input\b

[match:Operator]
pattern: =>?|[-+&/\\*^]=

[match:Operator]
pattern: [-+&/\\*^]

[match:Operator]
pattern: =|<>|<=|<|>=|>

[match:Error]
pattern: &h\w*\b

[match:Error]
pattern: &o\w*\b

[match:Error]
pattern: &b\w*\b

[match:Float]
pattern: \b\d+[f!#]

