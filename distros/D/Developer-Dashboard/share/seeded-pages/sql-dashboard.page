        my $column_sth = $dbh->column_info( undef, undef, $selected_table, '%' );
        while ( my $row = $column_sth->fetchrow_hashref ) {
            push @columns, {
                TABLE_NAME  => $selected_table,
                COLUMN_NAME => $row->{COLUMN_NAME},
                DATA_TYPE   => $row->{DATA_TYPE},
                DATA_LENGTH => $row->{DATA_LENGTH},
            };
        }
        $column_sth->finish if $column_sth && $column_sth->can('finish');
    }
    $dbh->disconnect if $dbh && $dbh->can('disconnect');
    $payload = {
        ok             => 1,
        selected_table => $selected_table,
        tables         => \@tables,
        columns        => \@columns,
    };
    1;
} or do {
    my $error = $@ || 'Unknown sql-dashboard schema failure';
    $error =~ s/\s+\z//;
    $payload = {
        ok             => 0,
        error          => $error,
        selected_table => '',
        tables         => [],
        columns        => [],
    };
};
print j $payload;

};
