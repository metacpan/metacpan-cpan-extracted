use strict;
use warnings;

$main::VERSION = 'v6.6.6';

use Getopt::Guided qw( EXIT_SUCCESS EXIT_FAILURE EXIT_USAGE print_version_info processopts );

sub run {
  shift;
  my @argv = @_ ? @_ : @ARGV;

  return EXIT_USAGE unless my $rv = processopts @argv, V => \&print_version_info, x => sub { };
  return EXIT_SUCCESS if $rv eq '-V';
  EXIT_FAILURE
}

exit( __PACKAGE__->run )
