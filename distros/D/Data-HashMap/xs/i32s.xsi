SV*
swap(SV* self_sv, int32_t key, SV* new_sv)
    CODE:
        EXTRACT_MAP(HashMapI32S, stash_i32s, "Data::HashMap::I32S", self_sv);
        STRLEN _nvl; const char* _nvs = SvPV(new_sv, _nvl); bool _nvu = SvUTF8(new_sv) ? true : false;
        const char* old; uint32_t old_len; bool old_utf8;
        if (!hashmap_i32s_swap(self, key, _nvs, (uint32_t)_nvl, _nvu, &old, &old_len, &old_utf8)) XSRETURN_UNDEF;
        RETVAL = newSVpvn(old, old_len);
        if (old_utf8) SvUTF8_on(RETVAL);
        free((void*)old);
    OUTPUT:
        RETVAL


