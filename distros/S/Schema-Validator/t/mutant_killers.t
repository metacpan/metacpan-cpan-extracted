# ===========================================================================
# SECTION 16: COND_INV_696_3 -- rdfs:Class grep inversion
#
# Source line 696:  if (grep { $_ eq $RDF_CLASS } @types) {
# Mutation: unless (grep { $_ eq $RDF_CLASS } @types)
#
# Items with @type rdfs:Class must go into %classes (first return value).
# Mutant indexes every OTHER type in %classes.
#
# Kill strategy: rdfs:Class item appears in returned hashref;
# rdf:Property item does NOT appear in returned hashref.
# ===========================================================================

subtest 'COND_INV_696_3: rdfs:Class item appears in classes; rdf:Property does not' => sub {
	# Mutant (unless): rdfs:Class goes into ELSE, rdf:Property goes into IF block.
	# We put both types in the graph and check which ends up where.

	my $graph = [
		{
			'@type'      => 'rdfs:Class',
			'rdfs:label' => 'OnlyInClasses',
			'@id'        => 'https://schema.org/OnlyInClasses',
		},
		{
			'@type'      => 'rdf:Property',
			'rdfs:label' => 'OnlyInProps',
			'@id'        => 'https://schema.org/OnlyInProps',
		},
	];

	my ($classes, $props) = Schema::Validator::_parse_graph($graph);

	# rdfs:Class goes into classes, NOT props
	ok( exists $classes->{OnlyInClasses}, 'COND_INV_696_3: rdfs:Class in classes hashref');
	ok(!exists $props->{OnlyInClasses},   'COND_INV_696_3: rdfs:Class NOT in props hashref');

	# rdf:Property goes into props, NOT classes
	ok(!exists $classes->{OnlyInProps}, 'COND_INV_696_3: rdf:Property NOT in classes hashref');
	ok( exists $props->{OnlyInProps},   'COND_INV_696_3: rdf:Property in props hashref');

	diag "Classes: " . join(',', keys %$classes)
		. " Props: " . join(',', keys %$props) if $ENV{TEST_VERBOSE};
};

