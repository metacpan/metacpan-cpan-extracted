from test/more import *;
is( 2 = 2, 1, "= numeric equality works" );
is( 2 != 3, 1, "!= numeric inequality works" );
is( 2 ≠ 3, 1, "≠ numeric inequality works" );
is( 2 < 3, 1, "< works" );
is( 2 <= 2, 1, "<= works" );
is( 2 ≤ 3, 1, "≤ works" );
is( 3 > 2, 1, "> works" );
is( 3 >= 3, 1, ">= works" );
is( 3 ≥ 2, 1, "≥ works" );
is( 1 <=> 9, -1, "<=> works" );
is( 9 ≶ 1, 1, "≶ works" );
is( 4 ≷ 4, 0, "≷ works" );
done_testing();
