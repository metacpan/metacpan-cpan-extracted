my $codec = Codec::CBOR->new();
#
sub normalize ($data) {
    return $data unless ref $data;
    return [ map { normalize($_) } @$data ]                       if ref $data eq 'ARRAY';
    return { map { $_ => normalize( $data->{$_} ) } keys %$data } if ref $data eq 'HASH';
    return $$data                                                 if ref $data eq 'SCALAR';
    $data;
}

