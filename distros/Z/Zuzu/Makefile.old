# --- MakeMaker postamble section:
install :: install_zuzu_dispatcher_$(INSTALLDIRS)

install_perl :: install_zuzu_dispatcher_perl

install_site :: install_zuzu_dispatcher_site

install_vendor :: install_zuzu_dispatcher_vendor

pure_install :: install_zuzu_dispatcher_$(INSTALLDIRS)

install_zuzu_dispatcher_ :: install_zuzu_dispatcher_site

install_zuzu_dispatcher_perl :: all
	$(NOECHO) $(MKPATH) "$(DESTINSTALLSCRIPT)"
	$(NOECHO) $(PERLRUN) -MFile::Copy=copy -e 'my ($$src, $$dest) = @ARGV; exit 0 if -e $$dest; copy($$src, $$dest) or die qq{Could not copy $$src to $$dest: $$!}; chmod 0755, $$dest or die qq{Could not chmod $$dest: $$!}' bin/zuzu "$(DESTINSTALLSCRIPT)$(DFSEP)zuzu"

install_zuzu_dispatcher_site :: all
	$(NOECHO) $(MKPATH) "$(DESTINSTALLSITESCRIPT)"
	$(NOECHO) $(PERLRUN) -MFile::Copy=copy -e 'my ($$src, $$dest) = @ARGV; exit 0 if -e $$dest; copy($$src, $$dest) or die qq{Could not copy $$src to $$dest: $$!}; chmod 0755, $$dest or die qq{Could not chmod $$dest: $$!}' bin/zuzu "$(DESTINSTALLSITESCRIPT)$(DFSEP)zuzu"

install_zuzu_dispatcher_vendor :: all
	$(NOECHO) $(MKPATH) "$(DESTINSTALLVENDORSCRIPT)"
	$(NOECHO) $(PERLRUN) -MFile::Copy=copy -e 'my ($$src, $$dest) = @ARGV; exit 0 if -e $$dest; copy($$src, $$dest) or die qq{Could not copy $$src to $$dest: $$!}; chmod 0755, $$dest or die qq{Could not chmod $$dest: $$!}' bin/zuzu "$(DESTINSTALLVENDORSCRIPT)$(DFSEP)zuzu"



