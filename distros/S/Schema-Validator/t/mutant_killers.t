# If mutant skips this, the fragment key is absent.
# ===========================================================================

subtest 'COND_INV_700_4: class @id creates secondary short-name index' => sub {
	# Label "SuperClass" differs from @id fragment "BaseClass".
	# Only if secondary index IS created can we find the item by "BaseClass".

	my $graph = [
		{
			'@type'      => 'rdfs:Class',
			'rdfs:label' => 'SuperClass',
			'@id'        => 'https://schema.org/BaseClass',
		},
	];

	my ($classes, $props) = Schema::Validator::_parse_graph($graph);

	# Accessible by label (always set)
	ok(exists $classes->{SuperClass}, 'COND_INV_700_4: class accessible by label');

	# Accessible by @id fragment ONLY if secondary index was created
	ok(exists $classes->{BaseClass},
		'COND_INV_700_4: class accessible by @id fragment (secondary index created)');

	# The two keys must point to the same item
	is($classes->{SuperClass}, $classes->{BaseClass},
		'COND_INV_700_4: label and @id fragment keys point to same item');

	diag "Class keys: " . join(',', keys %$classes) if $ENV{TEST_VERBOSE};
};

