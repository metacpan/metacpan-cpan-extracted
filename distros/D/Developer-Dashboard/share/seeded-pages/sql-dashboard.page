    for my $item ( @{ $collection->{items} } ) {
        die "Collection item must be a JSON object\n" if ref($item) ne 'HASH';
        my $name = sql_dashboard_trim( $item->{name} );
        my $id   = sql_dashboard_trim( $item->{id} );
